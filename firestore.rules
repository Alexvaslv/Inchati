rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }
    function isValidString(val, min, max) {
      return val is string && val.size() >= min && val.size() <= max;
    }
    function isAdmin() {
      return isAuthenticated() &&
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "alexeivasilev270819942@gmail.com" && request.auth.token.email_verified == true));
    }
    function isBanned() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isBanned', false) == true;
    }
    function isMuted() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isMuted', false) == true;
    }
    function isFrozen() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isFrozen', false) == true;
    }

    function isValidUsername(username, isVerified) {
      return username is string && (
        (isVerified && username.matches("^[a-zA-Z0-9]{3,15}$")) ||
        (!isVerified && username.matches("^[a-zA-Z0-9]{5,15}$"))
      );
    }
    function isValidName(name) {
      return name is string && name.size() <= 50;
    }

    // User Profiles
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && 
        request.resource.data.keys().hasAll(['uid', 'email', 'username', 'firstName', 'lastName']) &&
        isValidUsername(request.resource.data.username, request.resource.data.get('isVerified', false)) &&
        isValidName(request.resource.data.firstName) &&
        isValidName(request.resource.data.lastName) &&
        (
          (request.auth.token.email == "alexeivasilev270819942@gmail.com" && request.resource.data.role == 'admin') ||
          (!('role' in request.resource.data) || request.resource.data.role == 'user')
        );
      allow update: if isAuthenticated() && !isBanned() && (
        (isOwner(userId) && 
         (request.resource.data.username == resource.data.username || isValidUsername(request.resource.data.username, resource.data.get('isVerified', false))) &&
         (!('firstName' in request.resource.data) || isValidName(request.resource.data.firstName)) &&
         (!('lastName' in request.resource.data) || isValidName(request.resource.data.lastName)) &&
         request.resource.data.role == resource.data.role &&
         request.resource.data.get('isVerified', false) == resource.data.get('isVerified', false) &&
         request.resource.data.get('isVip', false) == resource.data.get('isVip', false) &&
         request.resource.data.get('isAdmin', false) == resource.data.get('isAdmin', false) &&
         request.resource.data.get('isModerator', false) == resource.data.get('isModerator', false) &&
         request.resource.data.get('isEditor', false) == resource.data.get('isEditor', false) &&
         request.resource.data.get('isCreator', false) == resource.data.get('isCreator', false) &&
         request.resource.data.get('isBanned', false) == resource.data.get('isBanned', false) &&
         request.resource.data.get('isMuted', false) == resource.data.get('isMuted', false) &&
         request.resource.data.get('isFrozen', false) == resource.data.get('isFrozen', false)
        ) || 
        isAdmin()
      );
      allow delete: if isAdmin();
      
      match /saved/{savedId} {
        allow read, write: if isOwner(userId);
      }
    }

    // Posts
    match /posts/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && !isBanned() && !isFrozen() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.likeCount == 0 &&
        request.resource.data.commentCount == 0;
      allow update: if isAuthenticated() && !isBanned() && (
        (isDocOwner() && !isFrozen() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['caption'])) ||
        (request.resource.data.diff(resource.data).affectedKeys().hasAny(['likeCount', 'commentCount']) &&
         math.abs(request.resource.data.likeCount - resource.data.likeCount) <= 1) ||
        isAdmin()
      );
      allow delete: if isDocOwner() || isAdmin();
    }

    // Stories
    match /stories/{storyId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && !isBanned() && !isFrozen() &&
        request.resource.data.userId == request.auth.uid;
      allow delete: if isDocOwner() || isAdmin();
    }

    // Chats
    match /chats/{chatId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated() && !isBanned() && request.auth.uid in request.resource.data.participants;
      allow update: if isAuthenticated() && request.auth.uid in resource.data.participants;
    }

    // Messages
    match /chats/{chatId}/messages/{messageId} {
      allow read: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      allow create: if isAuthenticated() && !isBanned() && !isMuted() && 
        request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants &&
        request.resource.data.senderId == request.auth.uid;
    }

    // Likes
    match /posts/{postId}/likes/{userId} {
      allow read: if isAuthenticated();
      allow create, delete: if isOwner(userId) && !isBanned();
    }

    // Comments
    match /posts/{postId}/comments/{commentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && !isBanned() && !isMuted() &&
        request.resource.data.userId == request.auth.uid &&
        isValidString(request.resource.data.text, 1, 1000);
      allow delete: if isAuthenticated() && !isBanned() && (
        resource.data.userId == request.auth.uid || 
        get(/databases/$(database)/documents/posts/$(postId)).data.userId == request.auth.uid ||
        isAdmin()
      );
    }

    // Username Uniqueness
    match /usernames/{username} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && !isBanned() && 
        (
          (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isVerified', false) && username.matches("^[a-zA-Z0-9]{3,15}$")) ||
          (!get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isVerified', false) && username.matches("^[a-zA-Z0-9]{5,15}$"))
        ) &&
        request.resource.data.uid == request.auth.uid;
      allow delete: if isAuthenticated() && 
        (resource.data.uid == request.auth.uid || isAdmin());
    }
  }
}
